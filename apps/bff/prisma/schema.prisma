// apps/bff/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id    String @id @default(uuid())
  name  String
  users User[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}
